' tst_picocalc_csub_bubblerow.bas -- CSUB CALLTABLE path from bubble.bas.
Option Explicit

Print "csub_bubblerow_start"
FRAMEBUFFER CREATE
FRAMEBUFFER WRITE F

Dim Float pf(15)
Dim Integer c(65), d(65), n(65)
Dim Integer i%, changed%, ct% = MM.INFO(CALLTABLE)

If ct% <= 0 Then Error "MM.INFO(CALLTABLE) returned zero"

pf(0) = 60
pf(1) = (2 * Pi) / 235 * 60
pf(2) = 0
pf(3) = 0
pf(4) = Pi / 2
pf(5) = MM.HRES / 4.2
pf(6) = MM.VRES / 4.0
pf(7) = MM.HRES \ 2
pf(8) = MM.VRES \ 2

bubblerow c(), d(), pf(), ct%

For i% = 0 To 65
  If c(i%) < 0 Or c(i%) >= MM.HRES Then Error "CSUB c() out of range"
  If d(i%) < 0 Or d(i%) >= MM.VRES Then Error "CSUB d() out of range"
  If c(i%) <> c(0) Or d(i%) <> d(0) Then changed% = 1
  n(i%) = RGB((i% * 3) Mod 256, 255 - ((i% * 2) Mod 256), 128)
Next i%

If changed% = 0 Then Error "CSUB did not populate row coordinates"

CLS RGB(BLACK)
PIXEL c(), d(), n()
FRAMEBUFFER COPY F, N
FRAMEBUFFER WRITE N
FRAMEBUFFER CLOSE F
Print "csub_bubblerow_done ct="; ct%; " sample="; c(0); ","; d(0)

CSUB bubblerow INTEGER, INTEGER, FLOAT, INTEGER
