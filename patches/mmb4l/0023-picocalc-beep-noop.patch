From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@example.com>
Date: Thu, 25 Jun 2026 00:00:00 -0700
Subject: [PATCH] Accept BEEP as a compatibility no-op

Old BASIC programs commonly use BEEP for simple feedback. The Luckfox
PicoCalc target does not currently provide a speaker/audio backend for this
command, but rejecting it stops otherwise-compatible text games and menu
programs.

Add BEEP as a visible command that consumes its command line and performs no
action. Keep it visible in LIST COMMANDS so compatibility tooling can identify
it and warn users that no audio will be generated.
---
 src/commands/cmd_dummy.c | 4 ++++
 src/core/commandtbl.c    | 1 +
 src/core/commandtbl.h    | 1 +
 3 files changed, 6 insertions(+)

diff --git a/src/commands/cmd_dummy.c b/src/commands/cmd_dummy.c
index 0ce116b..5e7a071 100644
--- a/src/commands/cmd_dummy.c
+++ b/src/commands/cmd_dummy.c
@@ -50,3 +50,7 @@ void cmd_dummy(void) {
 void cmd_dummy(void) {
     // Commands that are allowed but ignored.
 }
+
+void cmd_beep(void) {
+    // Compatibility no-op: audio output is not currently supported.
+}
diff --git a/src/core/commandtbl.c b/src/core/commandtbl.c
index 552637b..9d26e14 100644
--- a/src/core/commandtbl.c
+++ b/src/core/commandtbl.c
@@ -157,5 +157,6 @@ const struct s_tokentbl commandtbl[] = {
     { "While",       T_CMD,              0, cmd_do       },
     { "XModem",      T_CMD,              0, cmd_xmodem   },
     { "Array",       T_CMD,              0, cmd_array   },
+    { "Beep",        T_CMD,              0, cmd_beep     },
     { "",            0,                  0, cmd_null,    }  // This dummy entry is always at the end.
 };
diff --git a/src/core/commandtbl.h b/src/core/commandtbl.h
index 807238a..8870506 100644
--- a/src/core/commandtbl.h
+++ b/src/core/commandtbl.h
@@ -62,6 +62,7 @@ void cmd_arc(void);
 
 void cmd_arc(void);
 void cmd_autosave(void);
+void cmd_beep(void);
 void cmd_blit();
 void cmd_box(void);
 void cmd_call(void);
