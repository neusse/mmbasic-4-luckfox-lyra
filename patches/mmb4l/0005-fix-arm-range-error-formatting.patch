From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: George <george@example.com>
Date: Mon, 22 Jun 2026 14:31:00 -0700
Subject: [PATCH] Fix integer range error formatting on ARM

MMINTEGER is int64_t. The legacy error formatter reads '%' placeholders as
int, so passing MMINTEGER values through varargs corrupts the argument stream
on 32-bit ARM. Format getint() range errors without the legacy '%' varargs
path so messages report the rejected value and bounds correctly.
---
 src/common/error.c | 16 ++++++++++++++++
 src/common/error.h |  1 +
 src/core/MMBasic.c |  2 +-
 3 files changed, 18 insertions(+), 1 deletion(-)

diff --git a/src/common/error.c b/src/common/error.c
index 50d9b26..83b8679 100644
--- a/src/common/error.c
+++ b/src/common/error.c
@@ -217,6 +217,22 @@ MmResult error_throw(MmResult result) {
     return error_throw_ex(result, mmresult_to_string(result));
 }
 
+MmResult error_throw_int_range(MMINTEGER value, MMINTEGER min, MMINTEGER max) {
+    char value_s[32];
+    char min_s[32];
+    char max_s[32];
+    char msg[128];
+
+    IntToStr(value_s, value, 10);
+    IntToStr(min_s, min, 10);
+    IntToStr(max_s, max, 10);
+
+    snprintf(msg, sizeof(msg), "%s is invalid (valid is %s to %s)",
+             value_s, min_s, max_s);
+
+    return error_throw_ex(kError, msg);
+}
+
 uint8_t error_to_exit_code(MmResult result) {
     switch (result) {
         case kOk:               return 0;
diff --git a/src/common/error.h b/src/common/error.h
index cf8d0ec..e99b568 100644
--- a/src/common/error.h
+++ b/src/common/error.h
@@ -72,6 +72,7 @@ void error_init(ErrorState *error_state);
 MmResult error_throw(MmResult result);
 MmResult error_throw_ex(MmResult result, const char *msg, ...);
 MmResult error_throw_legacy(const char *msg, ...);
+MmResult error_throw_int_range(MMINTEGER value, MMINTEGER min, MMINTEGER max);
 uint8_t error_to_exit_code(MmResult result);
 
 #define ON_FAILURE_ERROR(x)  { \
diff --git a/src/core/MMBasic.c b/src/core/MMBasic.c
index e47be5d..7c6d227 100644
--- a/src/core/MMBasic.c
+++ b/src/core/MMBasic.c
@@ -1151,7 +1151,7 @@ MMINTEGER getinteger(const char *p) {
 // this will correctly round the number if it is a fraction of an integer
 MMINTEGER getint(const char *p, MMINTEGER min, MMINTEGER max) {
     MMINTEGER i = getinteger(p);
-    if (i < min || i > max) error("% is invalid (valid is % to %)", i, min, max);
+    if (i < min || i > max) error_throw_int_range(i, min, max);
     return i;
 }
 
