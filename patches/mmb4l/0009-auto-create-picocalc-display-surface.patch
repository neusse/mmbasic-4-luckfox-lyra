+static uint32_t blend_rgba(uint32_t c00, uint32_t c10, uint32_t c01, uint32_t c11, float tx,
+                           float ty) {
+    const float w00 = (1.0f - tx) * (1.0f - ty);
+    const float w10 = tx * (1.0f - ty);
+    const float w01 = (1.0f - tx) * ty;
+    const float w11 = tx * ty;
+    uint32_t out = 0;
+    for (int shift = 0; shift <= 24; shift += 8) {
+        const float channel = (float)((c00 >> shift) & 0xFF) * w00
+                            + (float)((c10 >> shift) & 0xFF) * w10
+                            + (float)((c01 >> shift) & 0xFF) * w01
+                            + (float)((c11 >> shift) & 0xFF) * w11;
+        out |= ((uint32_t)(channel + 0.5f) & 0xFF) << shift;
+    }
+    return out;
+}
+
+/**
+ * IMAGE RESIZE x, y, width, height, new_x, new_y, new_width, new_height [, src_id] [, flag]
