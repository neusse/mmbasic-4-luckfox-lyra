+
+#define WRITE_OR_CLEANUP(x) \
+    do { \
+        result = (x); \
+        if (FAILED(result)) goto cleanup; \
+    } while (false)
+
+    const uint8_t signature[2] = { 'B', 'M' };
+    WRITE_OR_CLEANUP(graphics_save_write(fnbr, signature, sizeof(signature)));
+    WRITE_OR_CLEANUP(graphics_save_u32_le(fnbr, file_size));
+    WRITE_OR_CLEANUP(graphics_save_u16_le(fnbr, 0));
+    WRITE_OR_CLEANUP(graphics_save_u16_le(fnbr, 0));
+    WRITE_OR_CLEANUP(graphics_save_u32_le(fnbr, pixel_offset));
+
+    WRITE_OR_CLEANUP(graphics_save_u32_le(fnbr, 40));
+    WRITE_OR_CLEANUP(graphics_save_u32_le(fnbr, (uint32_t) w));
+    WRITE_OR_CLEANUP(graphics_save_u32_le(fnbr, (uint32_t) h));
+    WRITE_OR_CLEANUP(graphics_save_u16_le(fnbr, 1));
+    WRITE_OR_CLEANUP(graphics_save_u16_le(fnbr, 24));
+    WRITE_OR_CLEANUP(graphics_save_u32_le(fnbr, 0));
