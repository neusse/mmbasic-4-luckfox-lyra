+static MmResult cmd_image_rotate_internal(const char *p, bool fast) {
+    getargs(&p, 17, ",");
+    if (argc < 13) return kArgumentCount;
+
+    const MmSurfaceId src_id = (argc >= 15 && *argv[14])
+            ? getint(argv[14], 0, GRAPHICS_MAX_ID)
+            : -1;
+    if (src_id != -1 && !graphics_surface_exists(src_id)) return kGraphicsInvalidReadSurface;
+    MmSurface *src_surface = (src_id == -1) ? graphics_current : &graphics_surfaces[src_id];
+    MmSurface *write_surface = graphics_current;
+
+    const int x = getint(argv[0], 0, src_surface->width - 1);
+    const int y = getint(argv[2], 0, src_surface->height - 1);
+    const int width = getint(argv[4], 1, src_surface->width - x);
+    const int height = getint(argv[6], 1, src_surface->height - y);
+    const int new_x = getint(argv[8], 0, write_surface->width - 1);
+    const int new_y = getint(argv[10], 0, write_surface->height - 1);
+    const float angle = (float) getnumber(argv[12]) * 3.14159265358979323846f / 180.0f;
+    const bool transparent_black = (argc == 17) && (getint(argv[16], 0, 1) == 1);
+
+    uint32_t *buffer = calloc(width * height, sizeof(uint32_t));
+    if (!buffer) return kOutOfMemory;
+    read_buffer_fast(src_surface, buffer, x, y, x + width - 1, y + height - 1);
+
+    const float cos_a = cosf(angle);
+    const float sin_a = sinf(angle);
+    const float cx = ((float) width - 1.0f) / 2.0f;
+    const float cy = ((float) height - 1.0f) / 2.0f;
+
+    for (int yy = 0; yy < height; ++yy) {
+        uint32_t *dst = write_surface->pixels + (new_y + yy) * write_surface->width + new_x;
+        const float dy = (float) yy - cy;
+        for (int xx = 0; xx < width; ++xx) {
+            const float dx = (float) xx - cx;
+            const float src_x = dx * cos_a + dy * sin_a + cx;
+            const float src_y = -dx * sin_a + dy * cos_a + cy;
+
+            if (src_x >= 0.0f && src_y >= 0.0f
+                    && src_x <= (float) (width - 1) && src_y <= (float) (height - 1)) {
+                uint32_t c;
+                if (fast) {
+                    const int sx = (int) (src_x + 0.5f);
+                    const int sy = (int) (src_y + 0.5f);
+                    c = buffer[sy * width + sx];
+                } else {
+                    const int x0 = (int) src_x;
+                    const int y0 = (int) src_y;
+                    const int x1 = min(x0 + 1, width - 1);
+                    const int y1 = min(y0 + 1, height - 1);
+                    c = blend_rgba(buffer[y0 * width + x0], buffer[y0 * width + x1],
+                                   buffer[y1 * width + x0], buffer[y1 * width + x1],
+                                   src_x - (float) x0, src_y - (float) y0);
+                }
+                if (!transparent_black || c != RGB_BLACK) *dst = c;
+            }
+            ++dst;
+        }
+    }
+
+    free(buffer);
+    write_surface->dirty = true;
+    return kOk;
+}
