+    const uint32_t file_size = pixel_offset + image_bytes;
+    const uint8_t padding[3] = { 0, 0, 0 };
+    const size_t padding_len = row_bytes - (uint32_t) (w * 3);
+
+    int fnbr = file_find_free();
