+MmResult graphics_save_bmp(MmSurface *surface, char *filename, int x, int y, int w, int h) {
+    if (!surface || surface->type == kGraphicsNone) return kGraphicsInvalidReadSurface;
+    if (w <= 0 || h <= 0 || x < 0 || y < 0 || x + w > surface->width || y + h > surface->height) {
+        return kInvalidArgument;
+    }
+    if (w & 1) return kInvalidArgument;
+
+    char _filename[STRINGSIZE];
+    MmResult result = cstring_cpy(_filename, filename, STRINGSIZE);
+    if (FAILED(result)) return result;
+    if (!path_has_extension(_filename, ".bmp", true)) {
+        result = cstring_cat(_filename, ".bmp", STRINGSIZE);
+        if (FAILED(result)) return kFilenameTooLong;
