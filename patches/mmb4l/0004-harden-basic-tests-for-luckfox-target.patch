From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: George <george@example.com>
Date: Mon, 22 Jun 2026 14:30:00 -0700
Subject: [PATCH] Harden BASIC tests for Luckfox target

Add assertions for the upstream ATAN3 placeholder test and make selected
MMB4L tests portable to the Luckfox Buildroot/BusyBox environment. The target
provides BusyBox realpath/readlink, not GNU coreutils realpath --relative-to,
and ADB shell is not an interactive console for cursor/terminal-size tests.
---
 tests/tst_file_fns.bas | 28 ++++++++++++++++++++++++----
 tests/tst_math.bas     |  7 ++++++-
 tests/tst_mminfo.bas   | 44 +++++++++++++++++++++++++++-----------------
 3 files changed, 57 insertions(+), 23 deletions(-)

diff --git a/tests/tst_file_fns.bas b/tests/tst_file_fns.bas
index 7d08a56..c1d12cc 100644
--- a/tests/tst_file_fns.bas
+++ b/tests/tst_file_fns.bas
@@ -625,7 +625,28 @@ Sub test_seek_errors()
   assert_int_equals(29, Loc(#1))
   Close #1
 End Sub
 
+Function relative_from_home$(path$, home$)
+  If home$ = "/" Then
+    relative_from_home$ = Mid$(path$, 2)
+    Exit Function
+  EndIf
+
+  If Left$(path$, Len(home$) + 1) = home$ + "/" Then
+    relative_from_home$ = Mid$(path$, Len(home$) + 2)
+    Exit Function
+  EndIf
+
+  Local depth% = 1, i%, rel$
+  For i% = 2 To Len(home$)
+    If Mid$(home$, i%, 1) = "/" Then Inc depth%
+  Next
+  For i% = 1 To depth%
+    Cat rel$, "../"
+  Next
+  relative_from_home$ = rel$ + Mid$(path$, 2)
+End Function
+
 Sub test_tilde_expansion()
   If Not sys.is_platform%("mmb4l") Then Exit Sub
 
@@ -641,9 +662,8 @@ Sub test_tilde_expansion()
   assert_string_equals(Mm.Info$(EnvVar "HOME"), Cwd$)
 
-  ' Use SYSTEM with 'realpath' to determine relative path from HOME to TMPDIR$.
-  Local s$
-  System "realpath --relative-to=$HOME " + TMPDIR$, s$
-  Local tmp_relative$ = "~/" + s$
+  ' BusyBox realpath does not support GNU --relative-to.
+  Local tmp_relative$ = "~/" + relative_from_home$(TMPDIR$, Mm.Info$(EnvVar "HOME"))
+  Local s$
 
   ChDir tmp_relative$
   assert_string_equals(TMPDIR$, Cwd$)
diff --git a/tests/tst_math.bas b/tests/tst_math.bas
index 17397c5..c92c31e 100644
--- a/tests/tst_math.bas
+++ b/tests/tst_math.bas
@@ -94,7 +94,12 @@ Sub test_log10()
 End Sub
 
 Sub test_atan3()
-  ' TODO
+  assert_float_equals(0, Math(Atan3 0, 1), 1e-10)
+  assert_float_equals(Pi / 2, Math(Atan3 1, 0), 1e-10)
+  assert_float_equals(Pi, Math(Atan3 0, -1), 1e-10)
+  assert_float_equals(3 * Pi / 2, Math(Atan3 -1, 0), 1e-10)
+  assert_float_equals(Pi / 4, Math(Atan3 1, 1), 1e-10)
+  assert_float_equals(5 * Pi / 4, Math(Atan3 -1, -1), 1e-10)
 End Sub
 
 Sub test_sd()
diff --git a/tests/tst_mminfo.bas b/tests/tst_mminfo.bas
index 59eb3f2..941ac40 100644
