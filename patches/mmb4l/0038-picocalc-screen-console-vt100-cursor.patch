diff --git a/src/common/picocalc_console.c b/src/common/picocalc_console.c
index e7fb4d1..cb1e90a 100644
--- a/src/common/picocalc_console.c
+++ b/src/common/picocalc_console.c
@@ -59,6 +59,23 @@ static PicocalcConsoleMode picocalc_console_cached_mode = kPicocalcConsoleTermin
 static int picocalc_console_cursor_x = 0;
 static int picocalc_console_cursor_y = 0;
 
+typedef enum {
+    kPicocalcVtIdle = 0,
+    kPicocalcVtEsc,
+    kPicocalcVtCsi,
+    kPicocalcVtOsc,
+} PicocalcVtState;
+
+static PicocalcVtState picocalc_vt_state = kPicocalcVtIdle;
+static char picocalc_vt_csi[32] = { 0 };
+static size_t picocalc_vt_csi_len = 0;
+
+static void picocalc_console_reset_vt(void) {
+    picocalc_vt_state = kPicocalcVtIdle;
+    picocalc_vt_csi_len = 0;
+    picocalc_vt_csi[0] = '\0';
+}
+
 static bool picocalc_console_env_is(const char *value, const char *expected) {
     return value && strcasecmp(value, expected) == 0;
 }
@@ -126,6 +143,7 @@ void picocalc_console_reset_detection(void) {
 void picocalc_console_reset_cursor(void) {
     picocalc_console_cursor_x = 0;
     picocalc_console_cursor_y = 0;
+    picocalc_console_reset_vt();
 }
 
 static bool picocalc_console_ensure_surface(void) {
@@ -134,6 +152,205 @@ static bool picocalc_console_ensure_surface(void) {
     return graphics_current != NULL;
 }
 
+static int picocalc_console_font_width(void) {
+    int width = (int) font_width(graphics_font);
+    return width > 0 ? width : 8;
+}
+
+static int picocalc_console_font_height(void) {
+    int height = (int) font_height(graphics_font);
+    return height > 0 ? height : 8;
+}
+
+static int picocalc_console_clamp(int value, int min_value, int max_value) {
+    if (max_value < min_value) return min_value;
+    if (value < min_value) return min_value;
+    if (value > max_value) return max_value;
+    return value;
+}
+
+static void picocalc_console_set_cursor_cells(int x, int y) {
+    if (!picocalc_console_ensure_surface()) {
+        picocalc_console_cursor_x = 0;
+        picocalc_console_cursor_y = 0;
+        return;
+    }
+
+    const int font_w = picocalc_console_font_width();
+    const int font_h = picocalc_console_font_height();
+    const int max_x = (graphics_current->width - font_w) / font_w;
+    const int max_y = (graphics_current->height - font_h) / font_h;
+    picocalc_console_cursor_x = picocalc_console_clamp(x, 0, max_x) * font_w;
+    picocalc_console_cursor_y = picocalc_console_clamp(y, 0, max_y) * font_h;
+}
+
+void picocalc_console_home_cursor(void) {
+    picocalc_console_reset_cursor();
+}
+
+void picocalc_console_set_cursor_pos(int x, int y) {
+    picocalc_console_set_cursor_cells(x, y);
+    picocalc_console_reset_vt();
+}
+
+void picocalc_console_cursor_up(int rows) {
+    if (rows <= 0) return;
+    if (!picocalc_console_ensure_surface()) {
+        picocalc_console_reset_cursor();
+        return;
+    }
+
+    const int font_h = picocalc_console_font_height();
+    picocalc_console_cursor_y = picocalc_console_clamp(
+            picocalc_console_cursor_y - rows * font_h,
+            0, graphics_current->height - font_h);
+    picocalc_console_reset_vt();
+}
+
+static void picocalc_console_move_cursor_cells(int dx, int dy) {
+    if (!picocalc_console_ensure_surface()) {
+        picocalc_console_reset_cursor();
+        return;
+    }
+
+    const int font_w = picocalc_console_font_width();
+    const int font_h = picocalc_console_font_height();
+    picocalc_console_set_cursor_cells(picocalc_console_cursor_x / font_w + dx,
+                                      picocalc_console_cursor_y / font_h + dy);
+}
+
+static void picocalc_console_clear_to_eol(void) {
+    if (!picocalc_console_ensure_surface()) return;
+
+    const int font_h = picocalc_console_font_height();
+    const int y2 = picocalc_console_clamp(picocalc_console_cursor_y + font_h - 1,
+                                          0, graphics_current->height - 1);
+    if (SUCCEEDED(graphics_draw_rectangle(graphics_current,
+                                          picocalc_console_cursor_x,
+                                          picocalc_console_cursor_y,
+                                          graphics_current->width - 1,
+                                          y2,
+                                          graphics_bcolour))) {
+        graphics_refresh_windows();
+    }
+}
+
+static int picocalc_console_csi_param(int index, int default_value) {
+    int current = 0;
+    int value = 0;
+    bool have_value = false;
+
+    const char *p = picocalc_vt_csi;
+    if (*p == '?') p++;
+
+    while (true) {
+        const char c = *p;
+        if (isdigit((unsigned char) c)) {
+            have_value = true;
+            value = value * 10 + (c - '0');
+        } else if (c == ';' || c == '\0') {
+            if (current == index) return have_value ? value : default_value;
+            current++;
+            value = 0;
+            have_value = false;
+            if (c == '\0') break;
+        }
+
+        if (c == '\0') break;
+        p++;
+    }
+
+    return default_value;
+}
+
+static void picocalc_console_handle_csi(char final) {
+    const int count = picocalc_console_csi_param(0, 1);
+
+    switch (final) {
+        case 'J':
+            picocalc_console_clear();
+            break;
+        case 'K':
+            picocalc_console_clear_to_eol();
+            break;
+        case 'H':
+        case 'f': {
+            const int row = picocalc_console_csi_param(0, 1);
+            const int col = picocalc_console_csi_param(1, 1);
+            picocalc_console_set_cursor_cells(col - 1, row - 1);
+            break;
+        }
+        case 'A':
+            picocalc_console_move_cursor_cells(0, -count);
+            break;
+        case 'B':
+            picocalc_console_move_cursor_cells(0, count);
+            break;
+        case 'C':
+            picocalc_console_move_cursor_cells(count, 0);
+            break;
+        case 'D':
+            picocalc_console_move_cursor_cells(-count, 0);
+            break;
+        case 'h':
+        case 'l':
+        case 'm':
+            break;
+        default:
+            break;
+    }
+}
+
+static bool picocalc_console_consume_vt(char c) {
+    const unsigned char uc = (unsigned char) c;
+
+    switch (picocalc_vt_state) {
+        case kPicocalcVtIdle:
+            if (uc == 0x1B) {
+                picocalc_vt_state = kPicocalcVtEsc;
+                return true;
+            }
+            return false;
+
+        case kPicocalcVtEsc:
+            if (c == '[') {
+                picocalc_vt_state = kPicocalcVtCsi;
+                picocalc_vt_csi_len = 0;
+                picocalc_vt_csi[0] = '\0';
+                return true;
+            }
+            if (c == ']') {
+                picocalc_vt_state = kPicocalcVtOsc;
+                return true;
+            }
+            picocalc_console_reset_vt();
+            return true;
+
+        case kPicocalcVtCsi:
+            if (uc >= 0x40 && uc <= 0x7E) {
+                picocalc_console_handle_csi(c);
+                picocalc_console_reset_vt();
+                return true;
+            }
+            if (picocalc_vt_csi_len + 1 < sizeof(picocalc_vt_csi)) {
+                picocalc_vt_csi[picocalc_vt_csi_len++] = c;
+                picocalc_vt_csi[picocalc_vt_csi_len] = '\0';
+            }
+            return true;
+
+        case kPicocalcVtOsc:
+            if (uc == 0x07) {
+                picocalc_console_reset_vt();
+            } else if (uc == 0x1B) {
+                picocalc_vt_state = kPicocalcVtEsc;
+            }
+            return true;
+    }
+
+    picocalc_console_reset_vt();
+    return true;
+}
+
 static void picocalc_console_newline(void) {
     const int font_h = (int) font_height(graphics_font);
     picocalc_console_cursor_x = 0;
@@ -173,6 +390,7 @@ static bool picocalc_console_draw_char(char c) {
 
 bool picocalc_console_putc(char c) {
     if (!picocalc_console_uses_screen()) return false;
+    if (picocalc_console_consume_vt(c)) return true;
     if (graphics_console_putc(c)) return true;
     if (!picocalc_console_ensure_surface()) return false;
 
