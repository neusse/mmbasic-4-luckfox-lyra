+#if !defined(MMB4L_LINUX_NETWORK_H)
+#define MMB4L_LINUX_NETWORK_H
+
+#include "mmresult.h"
+
+#include <stdbool.h>
+#include <stddef.h>
+
+typedef enum {
+    kLinuxNetworkTcpIpDown = 0,
+    kLinuxNetworkTcpIpWifiNoIp = 2,
+    kLinuxNetworkTcpIpHasIp = 3,
+} LinuxNetworkTcpIpStatus;
+
+MmResult linux_network_get_ip_address(char *buf, size_t buf_sz);
+MmResult linux_network_get_wifi_status(int *status);
+MmResult linux_network_get_tcpip_status(int *status);
+MmResult linux_network_get_wireless_interface(char *buf, size_t buf_sz);
+MmResult linux_network_scan_wifi(void);
+
+#endif
