+#include "../common/mmb4l.h"
+#include "../common/error.h"
+#include "../common/linux_network.h"
+#include "../common/parse.h"
+#include "../common/utility.h"
+
+static void cmd_web_scan(const char *p) {
+    if (!parse_is_end(p)) ERROR_SYNTAX;
+    ON_FAILURE_ERROR(linux_network_scan_wifi());
+}
+
+void cmd_web(void) {
+    const char *p;
+    if ((p = checkstring(cmdline, "SCAN"))) {
+        cmd_web_scan(p);
+    } else {
+        ERROR_UNKNOWN_SUBCOMMAND("WEB");
+    }
+}
diff --git a/src/common/linux_network.c b/src/common/linux_network.c
new file mode 100644
index 0000000..f858fcf
--- /dev/null
+++ b/src/common/linux_network.c
@@ -0,0 +1,180 @@
+#include "linux_network.h"
+
+#include "console.h"
+#include "cstring.h"
+#include "utility.h"
+
+#include <arpa/inet.h>
+#include <ctype.h>
+#include <errno.h>
+#include <ifaddrs.h>
+#include <net/if.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/socket.h>
+#include <unistd.h>
+
+static bool linux_network_is_wireless_name(const char *name) {
+    return strncmp(name, "wlan", 4) == 0 || strncmp(name, "wl", 2) == 0;
+}
+
+static bool linux_network_interface_is_up(const char *name) {
+    char path[128];
+    snprintf(path, sizeof(path), "/sys/class/net/%s/operstate", name);
+    FILE *f = fopen(path, "r");
+    if (!f) return false;
+
+    char state[16] = { 0 };
+    bool up = fgets(state, sizeof(state), f) && strncmp(state, "up", 2) == 0;
+    fclose(f);
+    return up;
+}
+
+static MmResult linux_network_get_ipv4_for_interface(
+        const char *preferred_iface,
+        bool prefer_wireless,
+        char *buf,
+        size_t buf_sz) {
+    struct ifaddrs *ifaddr = NULL;
+    if (getifaddrs(&ifaddr) == -1) return errno;
+
+    bool found = false;
+    for (struct ifaddrs *ifa = ifaddr; ifa; ifa = ifa->ifa_next) {
+        if (!ifa->ifa_addr || ifa->ifa_addr->sa_family != AF_INET) continue;
+        if (!(ifa->ifa_flags & IFF_UP) || (ifa->ifa_flags & IFF_LOOPBACK)) continue;
+        if (preferred_iface && strcmp(ifa->ifa_name, preferred_iface) != 0) continue;
+        if (prefer_wireless && !linux_network_is_wireless_name(ifa->ifa_name)) continue;
+
+        const struct sockaddr_in *addr = (const struct sockaddr_in *) ifa->ifa_addr;
+        if (!inet_ntop(AF_INET, &addr->sin_addr, buf, buf_sz)) {
+            freeifaddrs(ifaddr);
+            return errno;
+        }
+        found = true;
+        break;
+    }
+
+    freeifaddrs(ifaddr);
+    if (!found) {
+        if (cstring_cpy(buf, "0.0.0.0", buf_sz)) return kStringTooLong;
+    }
+    return kOk;
+}
+
+MmResult linux_network_get_ip_address(char *buf, size_t buf_sz) {
+    MmResult result = linux_network_get_ipv4_for_interface(NULL, true, buf, buf_sz);
+    if (FAILED(result)) return result;
+    if (strcmp(buf, "0.0.0.0") != 0) return kOk;
+    return linux_network_get_ipv4_for_interface(NULL, false, buf, buf_sz);
+}
+
+MmResult linux_network_get_wireless_interface(char *buf, size_t buf_sz) {
+    FILE *f = fopen("/proc/net/wireless", "r");
+    if (f) {
+        char line[256];
+        while (fgets(line, sizeof(line), f)) {
+            char *colon = strchr(line, ':');
+            if (!colon) continue;
+            *colon = '\0';
+            char *name = cstring_trim(line);
+            if (*name && linux_network_interface_is_up(name)) {
+                MmResult result = cstring_cpy(buf, name, buf_sz) ? kStringTooLong : kOk;
+                fclose(f);
+                return result;
+            }
+        }
+        fclose(f);
+    }
+
+    struct ifaddrs *ifaddr = NULL;
+    if (getifaddrs(&ifaddr) == -1) return errno;
+
+    bool found = false;
+    for (struct ifaddrs *ifa = ifaddr; ifa; ifa = ifa->ifa_next) {
+        if (!ifa->ifa_name || !linux_network_is_wireless_name(ifa->ifa_name)) continue;
+        if (!(ifa->ifa_flags & IFF_UP)) continue;
+        if (cstring_cpy(buf, ifa->ifa_name, buf_sz)) {
+            freeifaddrs(ifaddr);
+            return kStringTooLong;
+        }
+        found = true;
+        break;
+    }
+    freeifaddrs(ifaddr);
+
+    if (!found) {
+        if (cstring_cpy(buf, "", buf_sz)) return kStringTooLong;
+    }
+    return kOk;
+}
+
+MmResult linux_network_get_wifi_status(int *status) {
+    char iface[IFNAMSIZ] = { 0 };
+    MmResult result = linux_network_get_wireless_interface(iface, sizeof(iface));
+    if (FAILED(result)) return result;
+    *status = iface[0] ? 1 : 0;
+    return kOk;
+}
+
+MmResult linux_network_get_tcpip_status(int *status) {
+    char ip[INET_ADDRSTRLEN] = { 0 };
+    MmResult result = linux_network_get_ip_address(ip, sizeof(ip));
+    if (FAILED(result)) return result;
+    if (strcmp(ip, "0.0.0.0") != 0) {
+        *status = kLinuxNetworkTcpIpHasIp;
+        return kOk;
+    }
+
+    int wifi = 0;
+    result = linux_network_get_wifi_status(&wifi);
+    if (FAILED(result)) return result;
+    *status = wifi ? kLinuxNetworkTcpIpWifiNoIp : kLinuxNetworkTcpIpDown;
+    return kOk;
+}
+
+static bool linux_network_line_starts_with_ssid(const char *line, const char **ssid) {
+    while (isspace((unsigned char) *line)) line++;
+    if (strncmp(line, "SSID:", 5) != 0) return false;
+    line += 5;
+    while (*line == ' ' || *line == '\t') line++;
+    *ssid = line;
+    return true;
+}
+
+MmResult linux_network_scan_wifi(void) {
+    char iface[IFNAMSIZ] = { 0 };
+    MmResult result = linux_network_get_wireless_interface(iface, sizeof(iface));
+    if (FAILED(result)) return result;
+    if (!iface[0]) return kUnsupportedOnCurrentDevice;
+
+    char command[128];
+    snprintf(command, sizeof(command), "iw dev %s scan 2>/dev/null", iface);
+    FILE *f = popen(command, "r");
+    if (!f) return errno;
+
+    char line[512];
+    int count = 0;
+    while (fgets(line, sizeof(line), f)) {
+        const char *ssid = NULL;
+        if (!linux_network_line_starts_with_ssid(line, &ssid)) continue;
+
+        char clean[STRINGSIZE];
+        if (cstring_cpy(clean, ssid, sizeof(clean))) {
+            pclose(f);
+            return kStringTooLong;
+        }
+        cstring_trim(clean);
+        if (!clean[0]) continue;
+
+        console_puts(clean);
+        console_puts("\r\n");
+        count++;
+    }
+
+    int rc = pclose(f);
+    if (rc == -1) return errno;
+    if (count == 0) console_puts("No WiFi networks found\r\n");
+    return kOk;
+}
