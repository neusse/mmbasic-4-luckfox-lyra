+
+    dest[0] = 0;
+    ON_FAILURE_ERROR(linux_http_request("POST", url, body, content_type, timeout, buf, &buf_sz, status));
+    dest[0] = (int64_t) buf_sz;
+}
+
+static void cmd_web_rest(const char *p) {
+    const char *p2;
+    if ((p2 = checkstring(p, "CLEAR HEADERS"))) {
+        cmd_web_rest_clear_headers(p2);
+    } else if ((p2 = checkstring(p, "HEADER"))) {
+        cmd_web_rest_header(p2);
+    } else if ((p2 = checkstring(p, "GET"))) {
+        cmd_web_rest_get(p2);
+    } else if ((p2 = checkstring(p, "POST"))) {
+        cmd_web_rest_post(p2);
+    } else {
+        ERROR_UNKNOWN_SUBCOMMAND("WEB REST");
+    }
 }
 
 void cmd_web(void) {
     const char *p;
     if ((p = checkstring(cmdline, "SCAN"))) {
