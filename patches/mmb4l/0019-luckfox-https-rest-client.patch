+static void get_longstring_arg(const char *arg, int arg_num, int64_t **dest, char **buf, size_t *buf_sz) {
+    char *ptr = findvar(arg, V_FIND | V_EMPTY_OK);
+    if ((vartbl[VarIndex].type & T_INT) && vartbl[VarIndex].dims[0] > 0 && vartbl[VarIndex].dims[1] == 0) {
+        *dest = (int64_t *) ptr;
+        *buf = ptr + 8;
+        *buf_sz = (vartbl[VarIndex].dims[0] - mmb_options.base) * 8;
+        return;
+    }
+    ERROR_ARG_NOT_INTEGER_ARRAY(arg_num);
+}
+
+static int64_t *get_integer_variable_arg(const char *arg) {
+    char *ptr = findvar(arg, V_FIND | V_EMPTY_OK);
+    if ((vartbl[VarIndex].type & T_INT) && vartbl[VarIndex].dims[0] == 0) return (int64_t *) ptr;
