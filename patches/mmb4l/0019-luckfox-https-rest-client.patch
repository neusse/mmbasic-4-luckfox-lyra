diff --git a/src/common/linux_http.c b/src/common/linux_http.c
new file mode 100755
index 0000000..32bb894
--- /dev/null
+++ b/src/common/linux_http.c
@@ -0,0 +1,202 @@
+#include "linux_http.h"
+
+#include "cstring.h"
+#include "mmb4l.h"
+#include "mmresult.h"
+#include "utility.h"
+
+#include <curl/curl.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <strings.h>
+#include <unistd.h>
+
+#define LINUX_HTTP_MAX_HEADERS 16
+
+static char s_headers[LINUX_HTTP_MAX_HEADERS][STRINGSIZE * 2];
+static size_t s_header_count = 0;
+static bool s_curl_initialised = false;
+
+typedef struct {
+    char *data;
+    size_t len;
+    size_t cap;
+    bool overflow;
+} LinuxHttpResponse;
+
+static MmResult linux_http_init(void) {
+    if (s_curl_initialised) return kOk;
+    CURLcode rc = curl_global_init(CURL_GLOBAL_DEFAULT);
+    if (rc != CURLE_OK) return mmresult_ex(kError, "libcurl init failed: %s", curl_easy_strerror(rc));
+    s_curl_initialised = true;
+    return kOk;
+}
+
+MmResult linux_http_clear_headers(void) {
+    s_header_count = 0;
+    return kOk;
+}
+
+static bool linux_http_header_name_matches(const char *line, const char *name) {
+    size_t name_len = strlen(name);
+    return strncasecmp(line, name, name_len) == 0 && line[name_len] == ':';
+}
+
+MmResult linux_http_set_header(const char *name, const char *value) {
+    if (!name[0] || strchr(name, ':') || strchr(name, '\r') || strchr(name, '\n')
+            || strchr(value, '\r') || strchr(value, '\n')) {
+        return kInvalidValue;
+    }
+
+    char line[STRINGSIZE * 2];
+    int n = snprintf(line, sizeof(line), "%s: %s", name, value);
+    if (n < 0 || (size_t) n >= sizeof(line)) return kStringTooLong;
+
+    for (size_t i = 0; i < s_header_count; ++i) {
+        if (linux_http_header_name_matches(s_headers[i], name)) {
+            strcpy(s_headers[i], line);
+            return kOk;
+        }
+    }
+
+    if (s_header_count >= LINUX_HTTP_MAX_HEADERS) return kContainerFull;
+    strcpy(s_headers[s_header_count++], line);
+    return kOk;
+}
+
+static size_t linux_http_write_cb(char *ptr, size_t size, size_t nmemb, void *userdata) {
+    LinuxHttpResponse *response = (LinuxHttpResponse *) userdata;
+    size_t bytes = size * nmemb;
+    if (bytes == 0) return 0;
+    if (response->len + bytes > response->cap) {
+        response->overflow = true;
+        return 0;
+    }
+    memcpy(response->data + response->len, ptr, bytes);
+    response->len += bytes;
+    return bytes;
+}
+
+static bool linux_http_headers_include(const char *name) {
+    for (size_t i = 0; i < s_header_count; ++i) {
+        if (linux_http_header_name_matches(s_headers[i], name)) return true;
+    }
+    return false;
+}
+
+static const char *linux_http_ca_info(void) {
+    const char *env = getenv("SSL_CERT_FILE");
+    if (env && env[0] && access(env, R_OK) == 0) return env;
+
+    static const char *paths[] = {
+        "/usr/lib/python3.11/site-packages/pip/_vendor/certifi/cacert.pem",
+        "/usr/lib/python3.10/site-packages/pip/_vendor/certifi/cacert.pem",
+        "/etc/ssl/certs/ca-certificates.crt",
+        "/etc/ssl/cert.pem",
+        NULL,
+    };
+    for (const char **path = paths; *path; ++path) {
+        if (access(*path, R_OK) == 0) return *path;
+    }
+    return NULL;
+}
+
+static MmResult linux_http_append_headers(struct curl_slist **headers, const char *content_type) {
+    for (size_t i = 0; i < s_header_count; ++i) {
+        struct curl_slist *next = curl_slist_append(*headers, s_headers[i]);
+        if (!next) return kOutOfMemory;
+        *headers = next;
+    }
+
+    if (content_type && content_type[0] && !linux_http_headers_include("Content-Type")) {
+        char line[STRINGSIZE * 2];
+        int n = snprintf(line, sizeof(line), "Content-Type: %s", content_type);
+        if (n < 0 || (size_t) n >= sizeof(line)) return kStringTooLong;
+        struct curl_slist *next = curl_slist_append(*headers, line);
+        if (!next) return kOutOfMemory;
+        *headers = next;
+    }
+
+    return kOk;
+}
+
+MmResult linux_http_request(
+        const char *method,
+        const char *url,
+        const char *body,
+        const char *content_type,
+        int timeout_seconds,
+        char *response,
+        size_t *response_sz,
+        int64_t *status) {
+    MmResult result = linux_http_init();
+    if (FAILED(result)) return result;
+
+    CURL *curl = curl_easy_init();
+    if (!curl) return kOutOfMemory;
+
+    LinuxHttpResponse response_state = {
+        .data = response,
+        .len = 0,
+        .cap = *response_sz,
+        .overflow = false,
+    };
+    *status = 0;
+    *response_sz = 0;
+    char error_buf[CURL_ERROR_SIZE] = { 0 };
+    struct curl_slist *headers = NULL;
+
+    result = linux_http_append_headers(&headers, content_type);
+    if (FAILED(result)) goto cleanup;
+
+    curl_easy_setopt(curl, CURLOPT_URL, url);
+    curl_easy_setopt(curl, CURLOPT_FOLLOWLOCATION, 1L);
+    curl_easy_setopt(curl, CURLOPT_NOSIGNAL, 1L);
+    curl_easy_setopt(curl, CURLOPT_TIMEOUT, (long) timeout_seconds);
+    curl_easy_setopt(curl, CURLOPT_USERAGENT, "mmb4l-luckfox/1.0");
+    curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, linux_http_write_cb);
+    curl_easy_setopt(curl, CURLOPT_WRITEDATA, &response_state);
+    curl_easy_setopt(curl, CURLOPT_ERRORBUFFER, error_buf);
+    if (headers) curl_easy_setopt(curl, CURLOPT_HTTPHEADER, headers);
+    const char *ca_info = linux_http_ca_info();
+    if (ca_info) curl_easy_setopt(curl, CURLOPT_CAINFO, ca_info);
+
+    if (strcasecmp(method, "POST") == 0) {
+        curl_easy_setopt(curl, CURLOPT_POSTFIELDS, body ? body : "");
+        curl_easy_setopt(curl, CURLOPT_POSTFIELDSIZE, (long) (body ? strlen(body) : 0));
+    } else if (strcasecmp(method, "GET") != 0) {
+        result = kInvalidValue;
+        goto cleanup;
+    }
+
+    CURLcode rc = curl_easy_perform(curl);
+    if (rc != CURLE_OK) {
+        if (response_state.overflow) {
+            result = kStringTooLong;
+        } else {
+            result = mmresult_ex(
+                    kError,
+                    "HTTPS REST failed: %s",
+                    error_buf[0] ? error_buf : curl_easy_strerror(rc));
+        }
+        goto cleanup;
+    }
+
+    long response_code = 0;
+    rc = curl_easy_getinfo(curl, CURLINFO_RESPONSE_CODE, &response_code);
+    if (rc != CURLE_OK) {
+        result = mmresult_ex(kError, "HTTPS REST status failed: %s", curl_easy_strerror(rc));
+        goto cleanup;
+    }
+
+    *status = response_code;
+    *response_sz = response_state.len;
+    result = kOk;
+
+cleanup:
+    if (headers) curl_slist_free_all(headers);
+    curl_easy_cleanup(curl);
+    return result;
+}
