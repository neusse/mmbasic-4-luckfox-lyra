+static void cmd_web_rest_get(const char *p) {
+    getargs(&p, 7, ",");
+    if (argc != 3 && argc != 5 && argc != 7) ERROR_SYNTAX;
+
+    char *url = getCstring(argv[0]);
+    int64_t *dest = NULL;
+    char *buf = NULL;
+    size_t buf_sz = 0;
+    get_longstring_arg(argv[2], 2, &dest, &buf, &buf_sz);
+
+    int64_t local_status = 0;
+    int64_t *status = argc >= 5 ? get_integer_variable_arg(argv[4]) : &local_status;
+    int timeout = argc == 7 ? getint(argv[6], 1, 600) : 30;
+
+    dest[0] = 0;
+    ON_FAILURE_ERROR(linux_http_request("GET", url, NULL, NULL, timeout, buf, &buf_sz, status));
+    dest[0] = (int64_t) buf_sz;
+}
+
+static void cmd_web_rest_post(const char *p) {
+    getargs(&p, 11, ",");
+    if (argc != 5 && argc != 7 && argc != 9 && argc != 11) ERROR_SYNTAX;
+
+    char *url = getCstring(argv[0]);
+    char *body = getCstring(argv[2]);
+    int64_t *dest = NULL;
+    char *buf = NULL;
+    size_t buf_sz = 0;
+    get_longstring_arg(argv[4], 3, &dest, &buf, &buf_sz);
+
+    int64_t local_status = 0;
+    int64_t *status = argc >= 7 ? get_integer_variable_arg(argv[6]) : &local_status;
+    const char *content_type = argc >= 9 ? getCstring(argv[8]) : "application/json";
