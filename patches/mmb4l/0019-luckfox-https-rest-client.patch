+    } else if ((p = checkstring(cmdline, "REST"))) {
+        cmd_web_rest(p);
+    } else if (checkstring(cmdline, "MQTT") || checkstring(cmdline, "UDP")
+            || checkstring(cmdline, "TELNET") || checkstring(cmdline, "TFTP")) {
+        ERROR_UNIMPLEMENTED("use Linux networking services for this WEB command");
     } else {
         ERROR_UNKNOWN_SUBCOMMAND("WEB");
     }
