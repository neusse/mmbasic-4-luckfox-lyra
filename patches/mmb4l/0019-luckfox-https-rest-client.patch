+MmResult linux_network_get_connected_ssid(char *buf, size_t buf_sz) {
+    char iface[IFNAMSIZ] = { 0 };
+    MmResult result = linux_network_get_wireless_interface(iface, sizeof(iface));
+    if (FAILED(result)) return result;
+    if (!iface[0]) {
+        if (cstring_cpy(buf, "", buf_sz)) return kStringTooLong;
+        return kOk;
+    }
+
+    char command[128];
+    snprintf(command, sizeof(command), "iw dev %s link 2>/dev/null", iface);
+    FILE *f = popen(command, "r");
+    if (!f) return errno;
+
+    char line[512];
+    bool found = false;
+    while (fgets(line, sizeof(line), f)) {
+        char *p = cstring_trim(line);
+        if (strncmp(p, "SSID:", 5) != 0) continue;
+        p += 5;
+        while (*p == ' ' || *p == '\t') p++;
+        if (cstring_cpy(buf, p, buf_sz)) {
+            pclose(f);
+            return kStringTooLong;
+        }
+        cstring_trim(buf);
+        found = true;
+        break;
+    }
+
+    int rc = pclose(f);
+    if (rc == -1) return errno;
+    if (!found && cstring_cpy(buf, "", buf_sz)) return kStringTooLong;
+    return kOk;
+}
