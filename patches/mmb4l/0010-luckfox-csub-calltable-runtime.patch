+static void cfunction_get_arg_types(const char *defp, int typ[10]) {
+    char buf[STRINGSIZE];
+    char argbuf[STRINGSIZE + STRINGSIZE / 2];
+    char *argv[19];
+    int argc = 0;
+    char *out = buf;
+
+    if (*defp == '(') defp++;
+    while (*defp && *defp != ')' && *defp != SINGLE_QUOTE) *out++ = *defp++;
+    *out = '\0';
+
+    const char *p = buf;
+    skipspace(p);
+    if (!*p) return;
+
+    makeargs(&p, 19, argbuf, argv, &argc, ",");
+    for (int i = 0; i < argc && i < 19; i += 2) {
+        CheckIfTypeSpecified(argv[i], &typ[i / 2], true);
+        typ[i / 2] &= ~T_IMPLIED;
+    }
+}
+
+long long int CallCFunction(
+        const char *CmdPtr,
+        const char *ArgList,
+        const char *DefP,
+        const char *CallersLinePtr) {
+    void *arg[10] = { NULL };
+    int typ[10] = { 0 };
+    long long int i64[10] = { 0 };
+    MMFLOAT ff[10] = { 0 };
+    char *sp = NULL;
+    int type = 0;
+
+    uint32_t *p = FindCFunctionRecord(CFunctionFlash, CmdPtr);
+    if (*p == 0xFFFFFFFF && CFunctionLibrary != NULL) {
+        p = FindCFunctionRecord(CFunctionLibrary, CmdPtr);
+    }
+    if (*p == 0xFFFFFFFF) ERROR_INTERNAL_FAULT;
+
+    cfunction_get_arg_types(DefP, typ);
+
+    CurrentLinePtr = CallersLinePtr;
+    if (*ArgList == '(') ArgList++;
+    skipspace(ArgList);
+    if (*ArgList != ')' && *ArgList != '\0') {
+        char argbuf[STRINGSIZE + STRINGSIZE / 2];
+        char *argv[19];
+        int argc = 0;
+        makeargs(&ArgList, 19, argbuf, argv, &argc, ",");
+        for (int i = 0; i < argc && i < 19; i += 2) {
+            char *argp = argv[i];
+            const char *after_var = skipvar(argp, false);
+            bool is_plain_var = isnamestart(*argp)
+                    && (*after_var == '\0' || *after_var == ')')
+                    && !(FindSubFun(argp, kFunction) >= 0 && strchr(argp, '(') != NULL);
+            if (is_plain_var) {
+                arg[i / 2] = findvar(argp, V_FIND | V_EMPTY_OK);
+                if (typ[i / 2] != 0 && !(TypeMask(vartbl[VarIndex].type) & typ[i / 2])) {
+                    error_throw_ex(kError, "Incompatible type");
+                }
+            } else {
+                switch (typ[i / 2]) {
+                    case T_INT:
+                        i64[i / 2] = getinteger(argp);
+                        arg[i / 2] = &i64[i / 2];
+                        break;
+                    case T_NBR:
+                        ff[i / 2] = getnumber(argp);
+                        arg[i / 2] = &ff[i / 2];
+                        break;
+                    case T_STR:
+                        arg[i / 2] = GetTempStrMemory();
+                        Mstrcpy(arg[i / 2], getstring(argp));
+                        break;
+                    default:
+                        type = T_NOTYPE;
+                        evaluate(argp, &ff[i / 2], &i64[i / 2], &sp, &type, false);
+                        if (type & T_NBR) {
+                            arg[i / 2] = &ff[i / 2];
+                        } else if (type & T_INT) {
+                            arg[i / 2] = &i64[i / 2];
+                        } else {
+                            arg[i / 2] = GetTempStrMemory();
+                            Mstrcpy(arg[i / 2], sp);
+                        }
+                        break;
+                }
+            }
+        }
+    }
+
+    cfunction_refresh_display_values();
+    cfunction_make_progmem_executable();
+
+    p++;
+    uint32_t offset_words = *p++;
+    uintptr_t entry = (uintptr_t) (p + offset_words);
+#if defined(__arm__)
+    entry |= 0x1;
+#endif
+    typedef long long int (*CSubFn)(void *, void *, void *, void *, void *, void *, void *, void *, void *, void *);
+    return ((CSubFn) entry)(
+            arg[0], arg[1], arg[2], arg[3], arg[4], arg[5], arg[6], arg[7], arg[8], arg[9]);
+}
