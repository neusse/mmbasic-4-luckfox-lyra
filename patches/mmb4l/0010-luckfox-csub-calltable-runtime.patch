+
+static uint32_t *FindCFunctionRecord(const char *records, const char *cmd_ptr) {
+    char *p = (char *) records;
+    while (*((uint64_t *) p) != 0xFFFFFFFFFFFFFFFFULL) {
+        uintptr_t addr = (uintptr_t) *((uint64_t *) p);
+        uint32_t size = *((uint32_t *) (p + 8));
+        if ((const char *) addr == cmd_ptr) return (uint32_t *) (p + 8);
+        p += 8 + 4 + size;
+        while ((uintptr_t) p % 8 != 0) p++;
+    }
+    return (uint32_t *) p;
+}
+
+static void cfunction_make_progmem_executable(void) {
+    static bool mprotect_done = false;
+    long page_size = sysconf(_SC_PAGESIZE);
+    if (page_size <= 0) error_throw_ex(kError, "Could not determine system page size");
+
+    uintptr_t start = (uintptr_t) ProgMemory & ~((uintptr_t) page_size - 1);
+    uintptr_t end = ((uintptr_t) ProgMemory + PROG_FLASH_SIZE + (uintptr_t) page_size - 1)
+            & ~((uintptr_t) page_size - 1);
+
+    if (!mprotect_done) {
+        if (mprotect((void *) start, end - start, PROT_READ | PROT_WRITE | PROT_EXEC) != 0) {
+            error_throw_ex(kError, "Could not make CSUB memory executable");
+        }
+        mprotect_done = true;
+    }
+    __builtin___clear_cache((char *) start, (char *) end);
+}
