-        ON_FAILURE_RETURN(graphics_buffer_create(1, display->width, display->height));
+    MmSurfaceId page_id = -1;
+    ON_FAILURE_RETURN(graphics_picocalc_page_to_surface_id(1, &page_id));
+    if (!graphics_surface_exists(page_id)) {
+        MmSurface *display = &graphics_surfaces[GRAPHICS_SURFACE_N];
+        ON_FAILURE_RETURN(graphics_buffer_create(page_id, display->width, display->height));
     }
 
     return kOk;
@@ -134,7 +183,7 @@ void cmd_page(void) {
     MmResult result = kOk;
