     if ((p = checkstring(cmdline, "WRITE"))) {
-        result = cmd_graphics_write(p);
+        result = cmd_page_write(p);
     } else if ((p = checkstring(cmdline, "COPY"))) {
         result = cmd_page_copy(p);
     } else if ((p = checkstring(cmdline, "DISPLAY"))) {
diff --git a/src/common/graphics.c b/src/common/graphics.c
index 7f18f74..555aa20 100644
--- a/src/common/graphics.c
+++ b/src/common/graphics.c
@@ -249,6 +249,20 @@ bool graphics_is_default_display_picocalc() {
     return graphics_default_display_is_picocalc;
 }
 
+MmResult graphics_picocalc_page_to_surface_id(MmSurfaceId page_id, MmSurfaceId *surface_id) {
+    if (!surface_id) return kInternalFault;
+
+    if (page_id == 0) {
+        *surface_id = GRAPHICS_SURFACE_N;
+        return kOk;
+    }
+    if (page_id >= 1 && page_id <= PICOCALC_PAGE_MAX) {
+        *surface_id = PICOCALC_PAGE_BASE + page_id - 1;
+        return kOk;
+    }
+    return kGraphicsInvalidSurface;
+}
+
 MmResult graphics_ensure_default_display() {
     if (graphics_current) return kOk;
 
