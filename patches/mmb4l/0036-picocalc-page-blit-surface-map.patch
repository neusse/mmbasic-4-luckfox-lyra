 /** PAGE COPY src_id TO dst_id [, when] [, transparent] */
-static inline MmResult cmd_page_copy(const char *p) {
-    return cmd_graphics_copy(p);
+static MmResult cmd_page_copy(const char *p) {
+    char ss[3];
+    ss[0] = tokenTO;
+    ss[1] = ',';
+    ss[2] = 0;
+    getargs(&p, 7, ss);
+    if (argc < 3 || !(argc % 2)) return kArgumentCount;
+
+    MmSurfaceId src_id = -1;
+    MmResult result = parse_read_page(argv[0], &src_id);
+    if (FAILED(result)) return result;
+    MmSurface *src_surface = &graphics_surfaces[src_id];
+
+    MmSurfaceId dst_id = -1;
+    result = parse_write_page(argv[2], &dst_id);
+    if (FAILED(result)) return result;
+    MmSurface *dst_surface = &graphics_surfaces[dst_id];
+
+    if (has_arg(4)) {
+        const char *arg = argv[4];
+        switch (toupper(*arg)) {
+            case 'I':
+            case 'B':
+            case 'D':
+                break;
+            default:
+                return kSyntax;
+        }
+    }
+
+    MmGraphicsColour transparent = -1;
+    if (has_arg(6)) {
+        const char *arg = argv[6];
+        if (toupper(*arg) == 'T' || *arg == '1') transparent = RGB_BLACK;
+    }
+
+    return graphics_copy(src_surface, dst_surface, transparent);
+}
+
+/** PAGE WRITE { id | NONE } */
+static MmResult cmd_page_write(const char *p) {
+    getargs(&p, 1, ",");
+    if (argc != 1) return kArgumentCount;
+    if (checkstring(argv[0], "NONE")) return graphics_surface_write(GRAPHICS_NONE);
+
+    MmSurfaceId page_id = -1;
+    MmResult result = parse_write_page(argv[0], &page_id);
+    if (SUCCEEDED(result)) result = graphics_surface_write(page_id);
+    return result;
 }
 
 /** PAGE DISPLAY n [, page] */
@@ -117,9 +164,11 @@ static MmResult cmd_page_ensure_picocalc_pages(void) {
 
     ON_FAILURE_RETURN(graphics_ensure_default_display());
 
-    if (!graphics_surface_exists(1)) {
