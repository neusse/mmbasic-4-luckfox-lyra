From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@example.com>
Date: Thu, 25 Jun 2026 00:00:00 -0700
Subject: [PATCH] Add MM.FONTWIDTH and MM.FONTHEIGHT aliases

Some PicoMite-era programs use MM.FONTWIDTH and MM.FONTHEIGHT directly
when converting character-grid layouts to pixel coordinates. MMB4L already
supports the same values through MM.INFO(FONTWIDTH) and
MM.INFO(FONTHEIGHT), but the direct aliases were not tokenized, so programs
without OPTION EXPLICIT silently treated them as ordinary variables with a
default value of zero.

Add the aliases as no-argument MM. functions backed by the same graphics font
metrics used by MM.INFO.
---
 CMakeLists.txt                     |  2 ++
 src/core/tokentbl.c                |  2 ++
 src/core/tokentbl.h                |  2 ++
 src/functions/fun_fontheight.c     | 49 +++++++++++++++++++++++++++++++
 src/functions/fun_fontwidth.c      | 49 +++++++++++++++++++++++++++++++
 src/functions/fun_mminfo.c         |  4 +--
 6 files changed, 106 insertions(+), 2 deletions(-)
 create mode 100644 src/functions/fun_fontheight.c
 create mode 100644 src/functions/fun_fontwidth.c

diff --git a/CMakeLists.txt b/CMakeLists.txt
index ecf18ac..51427f3 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -148,6 +148,8 @@ set(mmbasic_SOURCE
     src/functions/fun_format.c
     src/functions/fun_field.c
     src/functions/fun_gamepad.c
+    src/functions/fun_fontheight.c
+    src/functions/fun_fontwidth.c
     src/functions/fun_hres.c
     src/functions/fun_inputstr.c
     src/functions/fun_json.c
diff --git a/src/core/tokentbl.c b/src/core/tokentbl.c
index 9056414..d57bd0e 100644
--- a/src/core/tokentbl.c
+++ b/src/core/tokentbl.c
@@ -118,6 +118,8 @@ const struct s_tokentbl tokentbl[] = {
     { "MM.Device$",  T_FNA | T_STR,      0, fun_mmdevice },
     { "MM.ErrMsg$",  T_FNA | T_STR,      0, fun_errmsg   },
     { "MM.Errno",    T_FNA | T_INT,      0, fun_errno    },
+    { "MM.FontHeight", T_FNA | T_INT,    0, fun_fontheight },
+    { "MM.FontWidth", T_FNA | T_INT,     0, fun_fontwidth },
     { "MM.HRes",     T_FNA | T_INT,      0, fun_hres     },
     { "MM.Info$(",   T_FUN | T_STR | T_INT | T_NBR, 0, fun_mminfo },
     { "MM.Info(",    T_FUN | T_STR | T_INT | T_NBR, 0, fun_mminfo },
diff --git a/src/core/tokentbl.h b/src/core/tokentbl.h
index 2561ef4..09331e3 100644
--- a/src/core/tokentbl.h
+++ b/src/core/tokentbl.h
@@ -74,6 +74,8 @@ void fun_exp(void);
 void fun_field(void);
 void fun_fix(void);
 void fun_format(void);
+void fun_fontheight(void);
+void fun_fontwidth(void);
 void fun_gamepad(void);
 void fun_hex(void);
 void fun_hres(void);
