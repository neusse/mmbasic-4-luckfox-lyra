+#include "picocalc_console.h"
+
+#include "fonttbl.h"
+#include "graphics.h"
+#include "utility.h"
+
+#include <ctype.h>
+#include <stdlib.h>
+#include <string.h>
+#include <strings.h>
+#include <unistd.h>
+
+static bool picocalc_console_mode_cached = false;
+static PicocalcConsoleMode picocalc_console_cached_mode = kPicocalcConsoleTerminal;
+static int picocalc_console_cursor_x = 0;
+static int picocalc_console_cursor_y = 0;
+
+static bool picocalc_console_env_is(const char *value, const char *expected) {
+    return value && strcasecmp(value, expected) == 0;
+}
+
+static bool picocalc_console_is_virtual_console(const char *path) {
+    if (!path) return false;
+    if (strcmp(path, "/dev/tty0") == 0) return true;
+    if (strncmp(path, "/dev/tty", 8) != 0) return false;
+
+    const char *p = path + 8;
+    if (!isdigit((unsigned char) *p)) return false;
+
+    int tty = 0;
+    while (*p) {
+        if (!isdigit((unsigned char) *p)) return false;
+        tty = tty * 10 + (*p - '0');
+        p++;
+    }
+    return tty >= 1 && tty <= 63;
+}
+
+PicocalcConsoleMode picocalc_console_mode(void) {
+    if (picocalc_console_mode_cached) return picocalc_console_cached_mode;
+
+    const char *env = getenv("MMB4L_PICOCALC_CONSOLE");
+    if (picocalc_console_env_is(env, "screen")
+            || picocalc_console_env_is(env, "fbdev")
+            || picocalc_console_env_is(env, "display")
+            || picocalc_console_env_is(env, "1")
+            || picocalc_console_env_is(env, "true")
+            || picocalc_console_env_is(env, "yes")) {
+        picocalc_console_cached_mode = kPicocalcConsoleScreen;
+    } else if (picocalc_console_env_is(env, "terminal")
+            || picocalc_console_env_is(env, "tty")
+            || picocalc_console_env_is(env, "0")
+            || picocalc_console_env_is(env, "false")
+            || picocalc_console_env_is(env, "no")) {
+        picocalc_console_cached_mode = kPicocalcConsoleTerminal;
+    } else if (isatty(STDIN_FILENO)) {
+        char tty_path[128] = { 0 };
+        if (ttyname_r(STDIN_FILENO, tty_path, sizeof(tty_path)) == 0
+                && picocalc_console_is_virtual_console(tty_path)) {
+            picocalc_console_cached_mode = kPicocalcConsoleScreen;
+        }
+    }
+
+    picocalc_console_mode_cached = true;
+    return picocalc_console_cached_mode;
+}
+
+const char *picocalc_console_mode_name(void) {
+    return picocalc_console_mode() == kPicocalcConsoleScreen ? "SCREEN" : "TERMINAL";
+}
+
+bool picocalc_console_uses_screen(void) {
+    return picocalc_console_mode() == kPicocalcConsoleScreen;
+}
+
+void picocalc_console_reset_detection(void) {
+    picocalc_console_mode_cached = false;
+    picocalc_console_cached_mode = kPicocalcConsoleTerminal;
+    picocalc_console_reset_cursor();
+}
+
+void picocalc_console_reset_cursor(void) {
+    picocalc_console_cursor_x = 0;
+    picocalc_console_cursor_y = 0;
+}
+
+static bool picocalc_console_ensure_surface(void) {
+    if (!picocalc_console_uses_screen()) return false;
+    if (FAILED(graphics_ensure_default_display())) return false;
+    return graphics_current != NULL;
+}
+
+static void picocalc_console_newline(void) {
+    const int font_h = (int) font_height(graphics_font);
+    picocalc_console_cursor_x = 0;
+    picocalc_console_cursor_y += font_h;
+    if (picocalc_console_cursor_y + font_h <= graphics_current->height) return;
+
+    if (SUCCEEDED(graphics_scroll(graphics_current, 0, font_h, graphics_bcolour))) {
+        picocalc_console_cursor_y = graphics_current->height - font_h;
+        graphics_refresh_windows();
+    } else {
+        picocalc_console_reset_cursor();
+    }
+}
+
+static bool picocalc_console_draw_char(char c) {
+    if (!picocalc_console_ensure_surface()) return false;
+
+    const int font_w = (int) font_width(graphics_font);
+    const int font_h = (int) font_height(graphics_font);
+    if (picocalc_console_cursor_x + font_w > graphics_current->width) {
+        picocalc_console_newline();
+    }
+
+    MmResult result = graphics_draw_char(graphics_current, &picocalc_console_cursor_x,
+                                        &picocalc_console_cursor_y, graphics_font,
+                                        graphics_fcolour, graphics_bcolour, c,
+                                        kOrientNormal);
+    if (FAILED(result)) return false;
+
+    if (picocalc_console_cursor_y + font_h > graphics_current->height) {
+        picocalc_console_newline();
+    } else {
+        graphics_refresh_windows();
+    }
+    return true;
+}
+
+bool picocalc_console_putc(char c) {
+    if (!picocalc_console_uses_screen()) return false;
+    if (graphics_console_putc(c)) return true;
+    if (!picocalc_console_ensure_surface()) return false;
+
+    switch (c) {
+        case '\b': {
+            const int font_w = (int) font_width(graphics_font);
+            if (picocalc_console_cursor_x >= font_w) {
+                picocalc_console_cursor_x -= font_w;
+            }
+            int x = picocalc_console_cursor_x;
+            int y = picocalc_console_cursor_y;
+            MmResult result = graphics_draw_char(graphics_current, &x, &y, graphics_font,
+                                                graphics_fcolour, graphics_bcolour, ' ',
+                                                kOrientNormal);
+            if (SUCCEEDED(result)) graphics_refresh_windows();
+            return SUCCEEDED(result);
+        }
+        case '\r':
+            picocalc_console_cursor_x = 0;
+            return true;
+        case '\n':
+            picocalc_console_newline();
+            return true;
+        case '\t':
+            for (int i = 0; i < 4; ++i) if (!picocalc_console_draw_char(' ')) return false;
+            return true;
+        default:
+            if ((unsigned char) c < 0x20 || (unsigned char) c == 0x7F) return true;
+            return picocalc_console_draw_char(c);
+    }
+}
+
+bool picocalc_console_clear(void) {
+    if (!picocalc_console_ensure_surface()) return false;
+    MmResult result = graphics_cls(graphics_current, graphics_bcolour);
+    if (FAILED(result)) return false;
+    picocalc_console_reset_cursor();
+    graphics_refresh_windows();
+    return true;
+}
