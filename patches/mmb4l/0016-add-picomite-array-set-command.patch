+#include <stdbool.h>
+#include <string.h>
+
+#include "../common/mmb4l.h"
+#include "../common/error.h"
+
+static bool is_whole_array_argument(const char *p) {
+    const char *open = strchr(p, '(');
+    if (open == NULL) return false;
+    const char *q = open + 1;
+    skipspace(q);
+    return *q == ')';
+}
+
+static int get_array_element_count(void) {
+    int count = 1;
+    for (int i = 0; i < MAXDIM && vartbl[VarIndex].dims[i] != 0; ++i) {
+        count *= vartbl[VarIndex].dims[i] + 1 - mmb_options.base;
+    }
+    return count;
+}
+
+static void cmd_array_set(const char *p) {
+    getargs(&p, 3, ",");
+    if (argc != 3) ERROR_ARGUMENT_COUNT;
+
+    void *ptr = findvar(argv[2], V_FIND | V_EMPTY_OK | V_NOFIND_ERR);
+    if (vartbl[VarIndex].type & T_CONST) ERROR_CANNOT_CHANGE_A_CONSTANT;
+    if (vartbl[VarIndex].dims[0] <= 0 || !is_whole_array_argument(argv[2])) ERROR_ARG_NOT_ARRAY(2);
+    if (ptr != vartbl[VarIndex].val.s) ERROR_ARG_NOT_ARRAY(2);
+
+    int count = get_array_element_count();
+    if (vartbl[VarIndex].type & T_NBR) {
+        MMFLOAT value = getnumber(argv[0]);
+        MMFLOAT *array = (MMFLOAT *)ptr;
+        for (int i = 0; i < count; ++i) array[i] = value;
+    } else if (vartbl[VarIndex].type & T_INT) {
+        MMINTEGER value = getinteger(argv[0]);
+        MMINTEGER *array = (MMINTEGER *)ptr;
+        for (int i = 0; i < count; ++i) array[i] = value;
+    } else if (vartbl[VarIndex].type & T_STR) {
+        char *value = getstring(argv[0]);
+        int max_len = vartbl[VarIndex].size;
+        if (*value > max_len) error_throw_ex(kError, "String too long");
+        char *array = (char *)ptr;
+        for (int i = 0; i < count; ++i) Mstrcpy(array + (i * (max_len + 1)), value);
+    } else {
+        ERROR_ARG_NOT_ARRAY(2);
+    }
+}
+
+void cmd_array(void) {
+    const char *p;
+    if ((p = checkstring(cmdline, "SET")) != NULL) {
+        cmd_array_set(p);
+    } else {
+        ERROR_UNKNOWN_SUBCOMMAND("ARRAY");
+    }
+}
